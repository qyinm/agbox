# PostHog capture credentials (maintainer / release CI only).
# Copy to ~/.agbox/.env for local testing, or set in your environment.
# Without POSTHOG_API_KEY, telemetry is on but capture is a no-op (no network calls).
# npm publish CI can bundle telemetry.env -> ~/.agbox/.env on first install when POSTHOG_API_KEY secret is set.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com